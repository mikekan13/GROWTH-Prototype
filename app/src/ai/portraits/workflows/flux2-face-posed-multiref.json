  "_comment": "FLUX.2 Dev — posed + multi-reference face identity workflow. The POSE slot (LOAD_POSE) takes a canonical composition template (e.g. bald head-and-shoulders portrait). We strip its identity signal by running it through Canny → RGB map so only structural edges remain. That edge map is VAE-encoded and chained as a ReferenceLatent anchor for composition/framing. The 1..N IDENTITY refs (LOAD_REF1..REF5) carry the actual face identity via chained ReferenceLatent. Provider strips unused REF slots and rewires BasicGuider.conditioning to whatever REFLAT_N is last in chain.",
  "LOAD_POSE": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "face-pose-template.png"
    },
    "_meta": {
      "title": "POSE_TEMPLATE"
    }
  },
  "POSE_SCALE": {
    "class_type": "ImageScaleToTotalPixels",
    "inputs": {
      "image": [
        "LOAD_POSE",
        0
      ],
      "upscale_method": "lanczos",
      "megapixels": 1,
      "resolution_steps": 1
    },
    "_meta": {
      "title": "Scale Pose to 1 MP"
    }
  },
  "POSE_CANNY": {
    "class_type": "Canny",
    "inputs": {
      "image": [
        "POSE_SCALE",
        0
      ],
      "low_threshold": 0.15,
      "high_threshold": 0.45
    },
    "_meta": {
      "title": "Canny Edges (identity stripped)"
    }
  },
  "POSE_ENCODE": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": [
        "POSE_CANNY",
        0
      ],
      "vae": [
        "10",
        0
      ]
    },
    "_meta": {
      "title": "Encode Pose Edges"
    }
  },
