{
  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "flux1-dev-Q4_0.gguf"
    },
    "_meta": { "title": "FLUX.1 Dev GGUF" }
  },
  "2": {
    "class_type": "DualCLIPLoaderGGUF",
    "inputs": {
      "clip_name1": "t5-v1_1-xxl-encoder-Q4_K_M.gguf",
      "clip_name2": "clip_l.safetensors",
      "type": "flux"
    },
    "_meta": { "title": "Dual CLIP Loader" }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "_meta": { "title": "VAE Loader" }
  },
  "4": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "",
      "t5xxl": "",
      "guidance": 3.5
    },
    "_meta": { "title": "Positive" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": ""
    },
    "_meta": { "title": "Negative" }
  },
  "6": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 768,
      "height": 768,
      "batch_size": 1
    },
    "_meta": { "title": "Empty Latent" }
  },

  "_comment_pulid": "── PuLID: Face Identity Lock ──",

  "10": {
    "class_type": "PulidFluxModelLoader",
    "inputs": {
      "pulid_file": "pulid_flux_v0.9.1.safetensors"
    },
    "_meta": { "title": "Load PuLID Flux Model" }
  },
  "11": {
    "class_type": "PulidFluxInsightFaceLoader",
    "inputs": {
      "provider": "CPU"
    },
    "_meta": { "title": "Load InsightFace" }
  },
  "14": {
    "class_type": "PulidFluxEvaClipLoader",
    "inputs": {},
    "_meta": { "title": "Load Eva Clip" }
  },
  "12": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "reference.png"
    },
    "_meta": { "title": "Reference Image (PuLID)" }
  },
  "13": {
    "class_type": "ApplyPulidFlux",
    "inputs": {
      "model": ["1", 0],
      "pulid_flux": ["10", 0],
      "eva_clip": ["14", 0],
      "face_analysis": ["11", 0],
      "image": ["12", 0],
      "weight": 0.8,
      "start_at": 0.0,
      "end_at": 1.0
    },
    "_meta": { "title": "Apply PuLID Flux" }
  },

  "_comment_controlnet": "── ControlNet: Pose/Angle Control ──",

  "20": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "angle_reference.png"
    },
    "_meta": { "title": "Angle Reference Image (ControlNet)" }
  },
  "21": {
    "class_type": "Canny_Edge_Preprocessor",
    "inputs": {
      "image": ["20", 0],
      "low_threshold": 100,
      "high_threshold": 200,
      "resolution": 768
    },
    "_meta": { "title": "Canny Edge Detection" }
  },
  "22": {
    "class_type": "LoadFluxControlNet",
    "inputs": {
      "model_name": "flux-dev",
      "controlnet_path": "flux-canny-controlnet-v3.safetensors"
    },
    "_meta": { "title": "Load XLabs ControlNet" }
  },
  "23": {
    "class_type": "ApplyFluxControlNet",
    "inputs": {
      "controlnet": ["22", 0],
      "image": ["21", 0],
      "strength": 0.65,
      "model": ["13", 0]
    },
    "_meta": { "title": "Apply ControlNet (Canny)" }
  },

  "_comment_sampler": "── Generation ──",

  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["23", 0],
      "seed": 42,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler" }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["3", 0]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "GROWTH_face_controlnet"
    },
    "_meta": { "title": "Save Image" }
  }
}
