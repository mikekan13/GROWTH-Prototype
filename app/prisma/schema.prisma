generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String     @unique
  passwordHash String
  role         String     @default("TRAILBLAZER") // ADMIN, WATCHER, TRAILBLAZER, GODHEAD
  campaigns    Campaign[]       @relation("GMCampaigns")
  characters   Character[]
  memberships  CampaignMember[]
  wallet       Wallet?
  sessions     Session[]
  accessCodes  AccessCode[]
  createdAt    DateTime   @default(now())
}

model Campaign {
  id              String           @id @default(cuid())
  name            String
  genre           String?
  themes          String?          // JSON array
  description     String?
  worldContext    String?          // World description for AI context
  customPrompts   String?          // JSON array of GM-defined backstory prompts
  gmUser          User             @relation("GMCampaigns", fields: [gmUserId], references: [id])
  gmUserId        String
  inviteCode      String?          @unique
  status          String           @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, ARCHIVED
  maxTrailblazers Int              @default(5)
  characters      Character[]
  members         CampaignMember[]
  changeLogs      ChangeLog[]
  sessions        GameSession[]
  events          CampaignEvent[]
  forgeItems      ForgeItem[]
  playerRequests  PlayerRequest[]
  locations       Location[]
  campaignItems   CampaignItem[]
  encounters      Encounter[]
  createdAt       DateTime         @default(now())
}

model CampaignMember {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  joinedAt   DateTime @default(now())

  @@unique([campaignId, userId])
}

model Character {
  id         String              @id @default(cuid())
  name       String
  user       User                @relation(fields: [userId], references: [id])
  userId     String
  campaign   Campaign            @relation(fields: [campaignId], references: [id])
  campaignId String
  data       String              // JSON<GrowthCharacter>
  portrait   String?
  status     String              @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, ACTIVE, DEAD, RETIRED
  backstory  CharacterBackstory?
  changeLogs ChangeLog[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model CharacterBackstory {
  id          String    @id @default(cuid())
  character   Character @relation(fields: [characterId], references: [id])
  characterId String    @unique
  responses   String    // JSON: array of { prompt: string, response: string }
  narrative   String?   // Combined/compiled narrative (generated from responses)
  gmNotes     String?
  status      String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REVISION
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Wallet {
  id        String  @id @default(cuid())
  owner     User?   @relation(fields: [ownerId], references: [id])
  ownerId   String? @unique
  ownerType String  // USER, RESERVE
  label     String? // For reserve wallets: "Terminal", "Mercy", "Balance", "Severity"
  balance   BigInt  @default(0)
}

model KrmaTransaction {
  id           String   @id @default(cuid())
  fromWalletId String
  toWalletId   String
  amount       BigInt
  reason       String
  createdAt    DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ChangeLog {
  id             String    @id @default(cuid())
  campaign       Campaign  @relation(fields: [campaignId], references: [id])
  campaignId     String
  character      Character @relation(fields: [characterId], references: [id])
  characterId    String
  characterName  String    @default("")
  groupId        String?

  actor          String    // player | gm | ai_copilot | system
  actorUserId    String

  category       String    // attribute | condition | inventory | etc.
  description    String
  changes        String    // JSON: FieldChange[]
  source         String?

  revertible     Boolean   @default(true)
  revertedAt     DateTime?
  revertedBy     String?

  snapshotBefore String?   // Full character JSON snapshot (nullable)

  createdAt      DateTime  @default(now())

  @@index([campaignId, createdAt])
  @@index([characterId, createdAt])
  @@index([groupId])
}

model GameSession {
  id         String          @id @default(cuid())
  campaign   Campaign        @relation(fields: [campaignId], references: [id])
  campaignId String
  number     Int             // Session 1, 2, 3...
  name       String?
  startedAt  DateTime        @default(now())
  endedAt    DateTime?
  events     CampaignEvent[]

  @@unique([campaignId, number])
  @@index([campaignId])
}

model CampaignEvent {
  id            String       @id @default(cuid())
  campaign      Campaign     @relation(fields: [campaignId], references: [id])
  campaignId    String
  session       GameSession? @relation(fields: [sessionId], references: [id])
  sessionId     String?
  type          String       // dice_roll | chat | command | ai_message | game_event
  actor         String       // player | gm | ai_copilot | system
  actorUserId   String
  actorName     String
  characterId   String?
  characterName String?
  payload       String       // JSON: type-specific payload
  createdAt     DateTime     @default(now())

  @@index([campaignId, createdAt])
  @@index([campaignId, type])
  @@index([sessionId])
}

model ForgeItem {
  id         String          @id @default(cuid())
  campaign   Campaign        @relation(fields: [campaignId], references: [id])
  campaignId String
  type       String          // skill | item | nectar | blossom | thorn
  name       String
  status     String          @default("draft") // draft | published
  data       String          // JSON: type-specific details (governors, description, etc.)
  createdBy  String          // userId of creator (GM)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  requests   PlayerRequest[]

  @@unique([campaignId, name, type])
  @@index([campaignId, type])
  @@index([campaignId, status])
}

model PlayerRequest {
  id          String     @id @default(cuid())
  campaign    Campaign   @relation(fields: [campaignId], references: [id])
  campaignId  String
  requesterId String     // userId of the requesting player
  type        String     // skill | item | nectar | blossom | thorn
  name        String     // Requested name
  status      String     @default("pending") // pending | approved | denied | modified
  data        String     // JSON: what the player wants (governors, description, etc.)
  gmNotes     String?    // GM feedback
  forgeItem   ForgeItem? @relation(fields: [forgeItemId], references: [id])
  forgeItemId String?    // Linked ForgeItem once approved/modified
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([campaignId, status])
  @@index([requesterId])
}

model Location {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  name        String
  type        String   @default("point_of_interest") // settlement | wilderness | dungeon | building | point_of_interest | region
  data        String   // JSON<GrowthLocation>
  status      String   @default("ACTIVE") // ACTIVE, HIDDEN, DESTROYED
  createdBy   String   // userId of creator (GM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, type])
}

model CampaignItem {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  name        String
  type        String   @default("misc") // weapon | armor | accessory | consumable | tool | artifact | prima_materia | misc
  data        String   // JSON<GrowthWorldItem>
  holderId    String?  // characterId of current holder (null = unowned/world item)
  locationId  String?  // locationId where item resides (null = carried/unknown)
  status      String   @default("ACTIVE") // ACTIVE, DESTROYED, CONSUMED, LOST
  createdBy   String   // userId of creator (GM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, type])
  @@index([holderId])
  @@index([locationId])
}

model Encounter {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  name        String
  type        String   @default("combat") // combat | social | exploration | puzzle | event
  status      String   @default("PLANNED") // PLANNED, ACTIVE, PAUSED, RESOLVED
  round       Int      @default(0)
  phase       String   @default("intention") // intention | resolution | impact
  data        String   // JSON<GrowthEncounter>
  locationId  String?  // Where this encounter takes place
  sessionId   String?  // Which game session
  createdBy   String   // userId of creator (GM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, status])
}

model AccessCode {
  id          String    @id @default(cuid())
  code        String    @unique
  role        String    @default("WATCHER") // Role granted on redemption
  label       String?   // "Kickstarter Backer", "Alpha Tester", etc.
  redeemedBy  User?     @relation(fields: [redeemedById], references: [id])
  redeemedById String?
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // Optional expiration
}
