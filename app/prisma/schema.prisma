generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  email              String     @unique
  passwordHash       String
  emailVerifiedAt    DateTime?
  role               String     @default("TRAILBLAZER") // ADMIN, WATCHER, TRAILBLAZER, GODHEAD
  profile            String?    // JSON<TrailblazerProfile>
  watcherProfile     String?    // JSON<WatcherProfile> (GM-specific, only for WATCHER/ADMIN roles)
  campaigns          Campaign[]       @relation("GMCampaigns")
  characters         Character[]
  memberships        CampaignMember[]
  wallet             Wallet?
  sessions           Session[]
  accessCodes        AccessCode[]
  emailVerifications EmailVerificationToken[]
  passwordResets     PasswordResetToken[]
  subscription       Subscription?
  createdAt          DateTime   @default(now())
}

// ── Auth: short-lived single-use tokens for email verification & password reset ──
// Issued by route handlers; consumed by the verify/reset endpoints. Tokens
// auto-expire via the expiresAt column (the consumer also checks it). On
// successful consumption we mark consumedAt so the row can be archived
// (kept for audit; not re-used). Cascade-delete with the user.

model EmailVerificationToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  token      String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  token      String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ── Subscription: tracks a paying GM through their lifecycle ─────────────
// Drives the monthlyDrip() schedule. Stripe IDs are optional so we can run
// dev/admin-flow subs without a Stripe account; the webhook layer fills
// them in when real billing comes online.
//
// status:
//   ACTIVE   — subscription is current; drips owed
//   PAST_DUE — payment failed; drips paused until ACTIVE again
//   CANCELED — user cancelled; no more drips; existing wallet KRMA stays
//   FREE     — admin-granted free tier; drips apply normally

model Subscription {
  id                  String   @id @default(cuid())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String   @unique
  status              String   @default("ACTIVE") // ACTIVE | PAST_DUE | CANCELED | FREE
  plan                String   @default("watcher_default")
  // Anchor for the monthlyDrip() curve. Set at subscribe time; immutable.
  subscribedAt        DateTime @default(now())
  // Tracking — last drip we successfully ran. NULL = lump not yet paid.
  lastDripAt          DateTime?
  lastDripMonthIndex  Int      @default(0) // 0 = lump only; N = monthly drip #N already paid
  // Stripe linkage (optional until billing comes online)
  stripeCustomerId    String?  @unique
  stripeSubId         String?  @unique
  // Free-form metadata
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model Campaign {
  id                  String               @id @default(cuid())
  name                String
  genre               String?
  themes              String?              // JSON array
  description         String?
  worldContext        String?              // World description for AI context
  customPrompts       String?              // JSON array of GM-defined backstory prompts (legacy)
  applicationTemplate String?              // JSON: [{ id, prompt, required, category }]
  listingStatus       String               @default("UNLISTED") // UNLISTED | LISTED | CLOSED
  listingDescription  String?              // Public-facing campaign pitch
  listingTags         String?              // JSON string[]
  requiredFields      String?              // JSON string[] — profile fields GM requires from applicants
  gmUser              User                 @relation("GMCampaigns", fields: [gmUserId], references: [id])
  gmUserId            String
  inviteCode          String?              @unique
  status              String               @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, ARCHIVED
  maxTrailblazers     Int                  @default(5)
  characters          Character[]
  members             CampaignMember[]
  applications        CampaignApplication[]
  copilotMessages     CopilotMessage[]
  changeLogs          ChangeLog[]
  sessions            GameSession[]
  events              CampaignEvent[]
  forgeItems          ForgeItem[]
  playerRequests      PlayerRequest[]
  locations           Location[]
  campaignItems       CampaignItem[]
  goals               Goal[]
  aiSettings          String?              // JSON<CampaignAISettings> — provider preferences per feature
  relationships       EntityRelationship[]
  godHeadMessages     GodHeadMessage[]
  jewlMistakes        JewlMistake[]
  // ── Time system (rulings 2026-06-08/-09) ──
  // Each campaign is a pocket universe with its own clock. The clock is
  // stored in META CYCLES (the universal abstract scale; 1 cycle ≈ 1
  // standard year) and rendered through Timescales/calendars at display.
  currentCycle        Float                @default(0)
  defaultTimescaleId  String?              // FK into Timescale (campaign's primary calendar)
  timescales          Timescale[]
  historyEntries      HistoryEntry[]
  createdAt           DateTime             @default(now())
}

// ── Timescale: a campaign-local calendar that converts between meta
// cycles and the GM's presented time. Carries the FULL customizable
// calendar (months/weeks/holidays — required at initial release per
// ruling r-2026-06-09-06) as a JSON spec. Locations may override the
// campaign default via data.timescaleId (inherits up the located_at
// chain otherwise).
model Timescale {
  id                String   @id @default(cuid())
  campaign          Campaign @relation(fields: [campaignId], references: [id])
  campaignId        String
  name              String   // "Tiberoak Reckoning"
  unitName          String   @default("year") // base local unit (singular)
  // Local base-units per ONE meta cycle. 2.0 = two Tiberoak years pass
  // per meta cycle (local time runs fast relative to meta).
  unitsPerMetaCycle Float    @default(1)
  // JSON<CalendarSpec> — months[{name,days}], dayNames[], hoursPerDay,
  // epoch{year,label}, holidays[{name,month,day,description}], seasons,
  // moons. See types/time.ts.
  calendar          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([campaignId])
}

// ── HistoryEntry: per-canvas-object, perspective-based history
// (ruling r-2026-06-09-07). One in-fiction event produces one entry PER
// INVOLVED OBJECT, written from that object's perspective — Locations
// log what happens in them; every PC and NPC carries a running
// experiential log. Entries created by the same event share an
// eventGroupId. Timestamped in meta cycles.
model HistoryEntry {
  id             String   @id @default(cuid())
  campaign       Campaign @relation(fields: [campaignId], references: [id])
  campaignId     String
  subjectType    String   // 'location' | 'character' | 'item' | 'campaign'
  subjectId      String   // the canvas object whose perspective this is
  timestampCycle Float    // campaign clock (meta cycles) when it happened
  type           String   // created|edited|arrival|departure|item_added|item_removed|status_change|clock_advance|harvest|narrative_event|combat
  summary        String   // one-liner from the subject's perspective
  details        String?
  actorId        String?  // who caused it (userId or characterId)
  visibility     String   @default("gm") // 'gm' | 'public'
  eventGroupId   String?  // links sibling perspective entries from one event
  realTime       DateTime @default(now())

  @@index([campaignId, subjectType, subjectId, timestampCycle])
  @@index([campaignId, eventGroupId])
}

model CampaignMember {
  id              String               @id @default(cuid())
  campaign        Campaign             @relation(fields: [campaignId], references: [id])
  campaignId      String
  user            User                 @relation(fields: [userId], references: [id])
  userId          String
  status          String               @default("INTERESTED") // INTERESTED, BACKSTORY, CHARACTER_CREATION, ACTIVE, REJECTED
  application     CampaignApplication?
  characterDesc   String?              // JSON: player's backstory + physical description before character exists
  // T28: the player submits their backstory FOR the GM's approval (GM approves
  // first — no player self-advance, ruling 2026-07-12). This is the signal the
  // GM sees; status only advances when the GM builds the character with them.
  // Portrait/identity work stays open while approval is pending.
  backstorySubmitted   Boolean          @default(false)
  backstorySubmittedAt DateTime?
  joinedAt        DateTime             @default(now())

  @@unique([campaignId, userId])
}

model CampaignApplication {
  id          String         @id @default(cuid())
  campaign    Campaign       @relation(fields: [campaignId], references: [id])
  campaignId  String
  member      CampaignMember @relation(fields: [memberId], references: [id])
  memberId    String         @unique
  responses       String         // JSON: [{ promptId, prompt, response, aiExpanded? }]
  profileSnapshot String?        // JSON: snapshot of profile at application time
  status          String         @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REVISION | DENIED
  gmNotes         String?
  characterId     String?        // linked after GM builds character
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([campaignId, status])
}

model Character {
  id         String              @id @default(cuid())
  name       String
  entityType String              @default("PLAYER_CHARACTER") // PLAYER_CHARACTER, NPC, CREATURE, GODHEAD
  user       User                @relation(fields: [userId], references: [id])
  userId     String
  campaign   Campaign?           @relation(fields: [campaignId], references: [id])
  campaignId String?             // Nullable: God-heads + global NPCs have no campaign
  data       String              // JSON<GrowthCharacter>
  portrait   String?
  status     String              @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, ACTIVE, DEAD, RETIRED
  backstory  CharacterBackstory?
  changeLogs ChangeLog[]
  portraitGenerations PortraitGeneration[]
  personaLock PersonaLock?
  godHead    GodHead?
  goals      Goal[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([entityType])
}

model CharacterBackstory {
  id          String    @id @default(cuid())
  character   Character @relation(fields: [characterId], references: [id])
  characterId String    @unique
  responses   String    // JSON: array of { prompt: string, response: string }
  narrative   String?   // Combined/compiled narrative (generated from responses)
  gmNotes     String?
  status      String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REVISION
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Wallet {
  id           String  @id @default(cuid())
  owner        User?   @relation(fields: [ownerId], references: [id])
  ownerId      String? @unique
  walletType   String  @default("USER")   // USER, RESERVE, CAMPAIGN, CHARACTER, BURN, LADY_DEATH
  ownerType    String  @default("USER")   // Kept for backwards compat; walletType is canonical
  label        String?                    // Reserve: "Terminal","Mercy","Balance","Severity"; System: "Burn Sink","Lady Death"
  balance      BigInt  @default(0)
  campaignId   String?                    // For CAMPAIGN wallets
  characterId  String?                    // For CHARACTER wallets
  frozen       Boolean @default(false)

  @@index([walletType])
  @@index([campaignId])
  @@index([characterId])
}

model KrmaTransaction {
  id              String   @id @default(cuid())
  sequenceNumber  BigInt   @unique
  fromWalletId    String
  toWalletId      String
  amount          BigInt
  state           String                  // FLUID, LOCK, UNLOCK, BURN
  reason          String                  // Transaction type code (e.g. CAMPAIGN_FUND)
  description     String   @default("")   // Human-readable explanation
  metadata        String   @default("{}") // JSON: TransactionMetadata
  campaignId      String?                 // Campaign context if applicable
  actorId         String                  // Who initiated
  actorType       String   @default("SYSTEM") // USER, SYSTEM, GM, EVALUATOR, GODHEAD
  checksum        String                  // SHA-256 chain link
  idempotencyKey  String?  @unique        // Prevents duplicate transactions
  createdAt       DateTime @default(now())

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([campaignId, createdAt])
  @@index([createdAt])
  @@index([reason])
}

model LedgerSequence {
  id      String @id @default("singleton")
  current BigInt @default(0)
}

model BurnLedger {
  id          String @id @default("singleton")
  totalBurned BigInt @default(0)
  cap         BigInt @default(5000000000)
}

model AuditEntry {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  actorId    String
  actorType  String
  action     String
  targetType String
  targetId   String
  outcome    String   // SUCCESS, DENIED, FAILED, ERROR
  reason     String   @default("")
  metadata   String   @default("{}")

  @@index([actorId])
  @@index([targetId])
  @@index([timestamp])
}

model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ChangeLog {
  id             String    @id @default(cuid())
  campaign       Campaign  @relation(fields: [campaignId], references: [id])
  campaignId     String
  character      Character @relation(fields: [characterId], references: [id])
  characterId    String
  characterName  String    @default("")
  groupId        String?

  actor          String    // player | gm | ai_copilot | system
  actorUserId    String

  category       String    // attribute | condition | inventory | etc.
  description    String
  changes        String    // JSON: FieldChange[]
  source         String?

  revertible     Boolean   @default(true)
  revertedAt     DateTime?
  revertedBy     String?

  snapshotBefore String?   // Full character JSON snapshot (nullable)

  createdAt      DateTime  @default(now())

  @@index([campaignId, createdAt])
  @@index([characterId, createdAt])
  @@index([groupId])
}

model GameSession {
  id         String          @id @default(cuid())
  campaign   Campaign        @relation(fields: [campaignId], references: [id])
  campaignId String
  number     Int             // Session 1, 2, 3...
  name       String?
  startedAt  DateTime        @default(now())
  endedAt    DateTime?
  events     CampaignEvent[]

  @@unique([campaignId, number])
  @@index([campaignId])
}

model CampaignEvent {
  id            String       @id @default(cuid())
  campaign      Campaign     @relation(fields: [campaignId], references: [id])
  campaignId    String
  session       GameSession? @relation(fields: [sessionId], references: [id])
  sessionId     String?
  type          String       // dice_roll | chat | command | ai_message | game_event
  actor         String       // player | gm | ai_copilot | system
  actorUserId   String
  actorName     String
  characterId   String?
  characterName String?
  payload       String       // JSON: type-specific payload
  createdAt     DateTime     @default(now())

  @@index([campaignId, createdAt])
  @@index([campaignId, type])
  @@index([sessionId])
}

model ForgeItem {
  id         String          @id @default(cuid())
  campaign   Campaign?       @relation(fields: [campaignId], references: [id])
  campaignId String?         // Nullable: global catalog items have no campaign
  type       String          // skill | item | nectar | blossom | thorn
  name       String
  status     String          @default("draft") // draft | published | global
  data       String          // JSON: type-specific details (governors, description, etc.)
  createdBy  String          // userId of creator (GM)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  requests   PlayerRequest[]

  // Global catalog
  isGlobal       Boolean     @default(false)   // True = lives in global catalog
  sourceGlobalId String?     // If this is a campaign instance of a global blueprint
  authorUserId   String?     // Original author (for royalty tracking, may differ from createdBy)

  // Authorship economy
  useCount       Int         @default(0)        // Times instantiated across campaigns
  royaltyRate    Float       @default(0.01)     // KRMA fraction paid to author on use

  // Blueprint decay (Lady Death)
  lastUsedAt     DateTime?                      // Last time this blueprint was instantiated
  decayStatus    String      @default("ACTIVE") // ACTIVE, FLAGGED, DISSOLVING, DISSOLVED
  flaggedAt      DateTime?

  // Karmic evaluation (Kai)
  relationshipTags String?   // JSON: [{ blueprintId, interactionType, synergyRisk }]
  karmicValue    BigInt?     // Locked value assigned by Kai
  evaluatedAt    DateTime?   // When Kai last scored this

  @@unique([campaignId, name, type])
  @@index([campaignId, type])
  @@index([campaignId, status])
  @@index([isGlobal, type])
  @@index([authorUserId])
  @@index([decayStatus])
}

model PlayerRequest {
  id          String     @id @default(cuid())
  campaign    Campaign   @relation(fields: [campaignId], references: [id])
  campaignId  String
  requesterId String     // userId of the requesting player
  type        String     // skill | item | nectar | blossom | thorn
  name        String     // Requested name
  status      String     @default("pending") // pending | approved | denied | modified
  data        String     // JSON: what the player wants (governors, description, etc.)
  gmNotes     String?    // GM feedback
  forgeItem   ForgeItem? @relation(fields: [forgeItemId], references: [id])
  forgeItemId String?    // Linked ForgeItem once approved/modified
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([campaignId, status])
  @@index([requesterId])
}

model Location {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  name        String
  type        String   @default("point_of_interest") // settlement | wilderness | dungeon | building | point_of_interest | region
  data        String   // JSON<GrowthLocation>
  status      String   @default("ACTIVE") // ACTIVE, HIDDEN, DESTROYED
  createdBy   String   // userId of creator (GM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, type])
}

model CampaignItem {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  name        String
  type        String   @default("misc") // weapon | armor | accessory | consumable | tool | artifact | prima_materia | misc
  data        String   // JSON<GrowthWorldItem>
  holderId    String?  // characterId of current holder (null = unowned/world item)
  locationId  String?  // locationId where item resides (null = carried/unknown)
  status      String   @default("ACTIVE") // ACTIVE, DESTROYED, CONSUMED, LOST
  createdBy   String   // userId of creator (GM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, type])
  @@index([holderId])
  @@index([locationId])
}

model CopilotMessage {
  id         String   @id @default(cuid())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  role       String   // user | assistant
  content    String
  userId     String?
  username   String?
  actions    String?  // JSON: CopilotAction[] — proposed actions
  metadata   String?  // JSON: retrieval context, tokens used, etc.
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
}

model PortraitGeneration {
  id              String    @id @default(cuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Image storage
  imagePath       String              // Relative path: portraits/{characterId}/{id}.png
  thumbnailPath   String?             // Smaller version for lists/tokens

  // Generation metadata
  prompt          String              // Full prompt used
  negativePrompt  String              // Full negative prompt used
  seed            Int
  model           String              // e.g. "flux1-dev-Q4_0"
  steps           Int
  pulidWeight     Float?
  styleLoraName   String?
  styleLoraWeight Float?
  generationTimeMs Int

  // State snapshot (character visual state at generation time)
  stateSnapshot   String              // JSON: PortraitCharacterData

  // Status
  status          String   @default("completed")  // pending, completed, failed, accepted, archived
  isCurrentPortrait Boolean @default(false)

  // Campaign context
  campaignId      String?

  createdAt       DateTime @default(now())

  @@index([characterId])
  @@index([characterId, isCurrentPortrait])
}

model PersonaLock {
  id              String   @id @default(cuid())
  characterId     String   @unique
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Identity anchors
  referenceImagePath  String          // Path to the locked reference portrait
  embeddingPath       String          // Path to face embedding file (Phase B)
  lockedPrompt        String          // The exact prompt that generated the accepted portrait
  lockedSeed          Int             // Seed of the accepted generation
  bodyDescription     String @default("") // Full body description for non-facial consistency

  // Style config at lock time
  styleLora       String?
  loraStrength    Float    @default(0.6)
  pulidWeight     Float    @default(0.8)

  // Lock history
  lockVersion     Int      @default(1)     // Increments on re-lock
  previousLockId  String?                  // Points to archived lock ID

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── God-Head Architecture ─────────────────────────────────────────────────

model Goal {
  id              String    @id @default(cuid())
  character       Character @relation(fields: [characterId], references: [id])
  characterId     String    // The entity that owns this goal (PC, NPC, God-head)
  campaign        Campaign? @relation(fields: [campaignId], references: [id])
  campaignId      String?   // Nullable: God-head meta-goals may be campaign-independent

  description     String    // Plain language ("Find my father's killer")
  status          String    @default("ACTIVE") // ACTIVE, DORMANT, COMPLETED, FAILED, ABANDONED (T34)
  priority        Int       @default(1) // 1-5, entity sets priority

  // God-head custodianship — which God-head "picked up" this GRO.vine
  custodianId     String?   // GodHead.id that adopted this goal
  custodianName   String?   // Cached display name
  pillar          String?   // MERCY, BALANCE, SEVERITY — inherited from custodian

  // Resistance (GM side)
  resistancePrompt String?  // Auto-generated prompt to GM
  resistancePlan   String?  // GM's plan/response

  // Progress tracking
  milestones      String?   // JSON: [{ id, description, completed, nectarAwarded?, completedAt? }]
  // Opportunity moments (T33): the O of GRO — GM-triggered leverage moments.
  opportunities   String?   // JSON: [{ id, description, narrative?, status: OPEN|RESOLVED, outcome?, method?, note?, declaredAt, resolvedAt? }]
  nectarsEarned   Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  @@index([characterId, status])
  @@index([campaignId, status])
  @@index([custodianId])
}

model EntityRelationship {
  id               String   @id @default(cuid())
  campaign         Campaign? @relation(fields: [campaignId], references: [id])
  campaignId       String?  // Nullable: some relationships are cross-campaign (God-head networks)

  // Source node
  sourceId         String   // Any entity ID (character, location, item, goal, god-head)
  sourceType       String   // CHARACTER, NPC, LOCATION, ITEM, GODHEAD, GOAL

  // Target node
  targetId         String
  targetType       String

  // Edge properties
  relationshipType String   // ally, rival, parent, guardian, custodian, located_at, owns, created_by, etc.
  strength         Int      @default(5) // 1-10
  bidirectional    Boolean  @default(false)
  data             String?  // JSON: relationship-specific metadata (e.g. shared history, tension points)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sourceId, targetId, relationshipType])
  @@index([campaignId])
  @@index([sourceId, sourceType])
  @@index([targetId, targetType])
}

model GodHead {
  id            String    @id @default(cuid())
  name          String    @unique // "Lady Death", "Kai", "Eth'erling"
  domain        String    // "Death, decay, karmic recycling, blueprint maintenance"
  pillar        String    // MERCY, BALANCE, SEVERITY
  character     Character @relation(fields: [characterId], references: [id])
  characterId   String    @unique // Links to Character record (universal sheet)

  // AI behavior. aiActionMode = false means the GodHead row exists (persona +
  // memory + identity) but a human (GM or player) is picking the character's
  // actions. true means the AI picks actions. Memory is captured either way.
  // Defaults to false so newly-minted personas don't immediately start acting
  // until the GM flips the toggle on the canvas character card. Legacy
  // godheads (Val, Thomas, etc.) are backfilled to true by the migration.
  aiActionMode  Boolean   @default(false)
  systemPrompt  String    // Core personality + domain authority instructions
  temperature   Float     @default(0.7)
  defaultModel  String?   // Anthropic model id this god-head prefers (claude-sonnet-4-6, claude-haiku-4-5-20251001, claude-opus-4-7). NULL = runtime default.

  // Economy
  walletId      String?   // God-head's KRMA wallet ID

  // Relations
  memory        GodHeadMemory[]
  invocations   GodHeadInvocation[]
  actionLogs    GodHeadActionLog[]
  tokenUsage    GodHeadTokenUsage[]
  messages      GodHeadMessage[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ── God-Head Agent Infrastructure ─────────────────────────────────────────

model GodHeadMemory {
  id          String   @id @default(cuid())
  godHead     GodHead  @relation(fields: [godHeadId], references: [id])
  godHeadId   String
  key         String   // Agent-managed key (e.g. "observations.kai.blueprint_preferences")
  value       String   // JSON — agent writes whatever it needs
  updatedAt   DateTime @updatedAt

  @@unique([godHeadId, key])
  @@index([godHeadId])
}

model GodHeadInvocation {
  id           String   @id @default(cuid())
  godHead      GodHead  @relation(fields: [godHeadId], references: [id])
  godHeadId    String
  triggerType  String   // goal.created, blueprint.created, gm.requested_council, manual, etc.
  triggerData  String   // JSON — context for the trigger
  status       String   @default("PENDING") // PENDING, RUNNING, DONE, FAILED
  result       String?  // JSON — final output/summary
  error        String?  // Error message if FAILED
  stepCount    Int      @default(0) // Number of tool calls in this invocation
  actionLogs   GodHeadActionLog[]
  tokenUsage   GodHeadTokenUsage[]
  messages     GodHeadMessage[]
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([godHeadId, status])
  @@index([status, createdAt])
}

model GodHeadActionLog {
  id            String           @id @default(cuid())
  invocation    GodHeadInvocation @relation(fields: [invocationId], references: [id])
  invocationId  String
  godHead       GodHead          @relation(fields: [godHeadId], references: [id])
  godHeadId     String
  toolName      String           // read_entity, draft_blueprint, transfer_krma, etc.
  input         String           // JSON — tool input parameters
  output        String?          // JSON — tool return value
  error         String?          // Error if tool call failed
  durationMs    Int?
  createdAt     DateTime         @default(now())

  @@index([invocationId])
  @@index([godHeadId, createdAt])
}

model GodHeadTokenUsage {
  id            String            @id @default(cuid())
  godHead       GodHead           @relation(fields: [godHeadId], references: [id])
  godHeadId     String
  invocation    GodHeadInvocation? @relation(fields: [invocationId], references: [id])
  invocationId  String?
  model         String            // claude-opus-4-6, claude-sonnet-4-6, etc.
  inputTokens   Int
  outputTokens  Int
  costEstimate  Float             @default(0) // USD estimate
  createdAt     DateTime          @default(now())

  @@index([godHeadId])
  @@index([invocationId])
}

model GodHeadMessage {
  id            String             @id @default(cuid())
  godHead       GodHead            @relation(fields: [godHeadId], references: [id])
  godHeadId     String
  campaign      Campaign           @relation(fields: [campaignId], references: [id])
  campaignId    String
  direction     String             // GODHEAD_TO_GM | GM_TO_GODHEAD
  content       String             // Message body (plain text or JSON for structured payloads)
  invocation    GodHeadInvocation? @relation(fields: [invocationId], references: [id])
  invocationId  String?
  readAt        DateTime?
  createdAt     DateTime           @default(now())

  @@index([campaignId, godHeadId, createdAt])
  @@index([godHeadId, readAt])
  @@index([invocationId])
}

// ── JEWL Mistake Bounty ──────────────────────────────────────────────────
//
// When a GM catches JEWL making a mistake (bad challenge, wrong reaction,
// missed context, factual error in an observation), they flag the offending
// CopilotMessage. The flag debits JEWL's GodHead wallet and credits the
// GM's user wallet via a JEWL_MISTAKE_BOUNTY KrmaTransaction.
//
// One row per (campaignId, copilotMessageId, gmUserId) — same GM can't
// double-flag the same message. Cross-campaign aggregation is intentional
// (this table is the corpus JEWL eventually trains on per
// [[jewl-is-the-interface-2026-06-15]]).
model JewlMistake {
  id               String   @id @default(cuid())
  campaign         Campaign @relation(fields: [campaignId], references: [id])
  campaignId       String
  // The assistant message JEWL produced that the GM is flagging.
  copilotMessageId String
  // The GM doing the flagging — they receive the bounty.
  gmUserId         String
  // The active GameSession at flag time (nullable — flag can happen outside a session).
  sessionId        String?
  severity         String   // minor | major | critical
  note             String   @default("")
  // PENDING bounty (resolved from EconomyConfig at flag time). No KRMA moves on
  // flag — the transfer fires on acceptance or an upheld dispute (T19, INV-121).
  bountyAmount     BigInt
  // Pointer to the KrmaTransaction that moved the KRMA. NULL until the bounty
  // actually pays (accepted, or dispute upheld). Overturned disputes never pay.
  transactionId    String?
  // Resolution lifecycle (T19):
  //   flagged      — GM raised the claim; no KRMA has moved yet.
  //   acknowledged — JEWL owned it → bounty paid (terminal).
  //   disputed     — JEWL pushed back → routed to Et'herling to adjudicate.
  //   resolved     — Et'herling ruled; see `resolution` for the outcome (terminal).
  status           String   @default("flagged")
  // Adjudicated outcome: accepted | upheld | overturned. Null while flagged/disputed.
  resolution       String?
  // GodHeadInvocation id for the Et'herling adjudication (dispute path only).
  adjudicationInvocationId String?
  createdAt        DateTime @default(now())

  @@unique([copilotMessageId, gmUserId])
  @@index([campaignId, createdAt])
  @@index([gmUserId, createdAt])
  @@index([sessionId])
}

model AccessCode {
  id          String    @id @default(cuid())
  code        String    @unique
  role        String    @default("WATCHER") // Role granted on redemption
  label       String?   // "Kickstarter Backer", "Alpha Tester", etc.
  redeemedBy  User?     @relation(fields: [redeemedById], references: [id])
  redeemedById String?
  redeemedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime? // Optional expiration
}

// ── EconomyConfig (T06) — ADMIN-tunable economy constants ────────────────
// Key/value store for numbers that are guesstimates pending a balancing pass
// (ruling 2026-07-10 / INV-17 AMENDED). Nothing here creates KRMA — these are
// transfer sizes and thresholds executed through the ledger (INV-13/14). The
// service layer parses `value` (JSON string, SQLite has no native JSON) and
// falls back to code defaults when a key is absent, so an empty table is safe.
model EconomyConfig {
  key       String   @id // e.g. "drip"
  value     String // JSON<config shape for this key>
  updatedAt DateTime @updatedAt
  updatedBy String? // ADMIN userId of last edit
}

// ============================================================
// Contract System (T13, INV-115) — Terminal-enforced obligations
// ============================================================

model Contract {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  // null = Terminal-level (global). Contracts authored on the Prime canvas
  // carry the __PRIME__ campaign id.
  campaignId  String?
  // JSON: ContractParty[] — {type, id, role?}
  parties     String
  // JSON: ContractPredicate DSL — the invariant that must HOLD.
  predicate   String
  // JSON: ContractPenalty — typed; destructive kinds require ADMIN confirmation.
  penalty     String
  deadline    DateTime?
  // Immutable contracts sit below the vote layer (INV-101 succession tier).
  // All mutation paths except seeding reject edits to their terms.
  immutable   Boolean   @default(false)
  // Deferred in-game vote/Triu-verification mechanism (ruling 2026-07-10 #2).
  voteRef     String?
  // ACTIVE | VIOLATED | FULFILLED | REVOKED (validated in service layer)
  status      String    @default("ACTIVE")
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  evaluations ContractEvaluation[]
  penaltyActions PenaltyAction[]

  @@index([status])
  @@index([campaignId])
}

// Append-only audit log — every evaluation is recorded (INV-14 spirit:
// the evaluator reads the ledger, never mutates it outside penalty
// transactions, and leaves a verifiable trail).
model ContractEvaluation {
  id          String   @id @default(cuid())
  contract    Contract @relation(fields: [contractId], references: [id])
  contractId  String
  // Did the predicate hold?
  holds       Boolean
  // JSON: EvaluationDetail — computed leaf values at evaluation time.
  detail      String
  // LEDGER_COMMIT | SWEEP | MANUAL
  trigger     String
  evaluatedAt DateTime @default(now())

  @@index([contractId, evaluatedAt])
}

model PenaltyAction {
  id          String    @id @default(cuid())
  contract    Contract  @relation(fields: [contractId], references: [id])
  contractId  String
  // ContractPenalty.kind at creation time
  kind        String
  // JSON: the full ContractPenalty payload frozen at violation time
  payload     String
  // PENDING_CONFIRMATION | EXECUTED | REJECTED
  status      String    @default("PENDING_CONFIRMATION")
  // ADMIN user id that confirmed/rejected
  resolvedBy  String?
  resolvedAt  DateTime?
  // Pointer to the KrmaTransaction if the execution moved KRMA
  transactionId String?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
  @@index([contractId])
}

// Lingering mana residue (r-2026-07-23-02): spent mana's KV stays WITH the
// spell and slowly fades back to the weave. Rows decay on clock advance
// (~dr cycles to fully fade). While present: godhead-attractable, tappable.
// NOTE: decay is bookkeeping-only for now — no KRMA transfer until mana KV
// custody is ruled (transferring would mint; see NEEDS-MIKE).
model ManaResidue {
  id            String   @id @default(cuid())
  campaignId    String
  characterId   String?
  spellName     String?
  method        String   // wild | woven
  dr            Int
  manaInitial   Int
  manaRemaining Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([campaignId])
}
